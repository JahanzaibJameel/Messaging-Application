{
  "expo": {
    "name": "ChatApp",
    "slug": "chatapp-2026",
    "version": "2.0.0",
    "runtimeVersion": "2.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splashScreen": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF",
      "dark": {
        "image": "./assets/images/splash-dark.png",
        "backgroundColor": "#0B141A"
      }
    },
    "icon": "./assets/images/icon.png",
    "favicon": "./assets/images/favicon.png",
    "scheme": "chatapp",
    "primaryColor": "#25D366",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "plugins": [
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/Inter-Regular.ttf", "./assets/fonts/Inter-Bold.ttf"]
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true,
      "tsfmt": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chatapp.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Allow ChatApp to discover devices on your local network",
        "NSBonjourServiceTypes": ["_http._tcp", "_ws._tcp"],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSExceptionMinimumTLSVersion": "TLSv1.0"
            },
            "127.0.0.1": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSExceptionMinimumTLSVersion": "TLSv1.0"
            },
            "10.0.2.2": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSExceptionMinimumTLSVersion": "TLSv1.0"
            }
          },
          "NSExceptionRequiresForwardSecrecy": false
        }
      }
    },
    "android": {
      "package": "com.chatapp.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#25D366",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "chatapp-2026"
      },
      "router": {
        "origin": false
      }
    }
  }
}
