{
  "name": "chatapp",
  "main": "client/App.tsx",
  "version": "3.0.0",
  "description": "Enterprise-grade WhatsApp-style chat app with Clean Architecture, offline-first sync, and premium UI",
  "scripts": {
    "dev": "npx expo start",
    "web": "npx expo start --web",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "build:web": "npx expo export --platform web",
    "preview:web": "npx http-server ./dist -p 3000",
    "server:dev": "NODE_ENV=development tsx server/index.ts",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "db:push": "drizzle-kit push",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit --strict",
    "validate": "npm run type-check && npm run lint && npm run format:check",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:performance": "jest --testPathPattern=performance.test.ts",
    "check:console": "node scripts/check-console-logs.js",
    "validate:env": "node scripts/validate-env.js",
    "audit:deps": "npm audit --audit-level high",
    "audit:deps:fix": "npm audit fix",
    "security:check": "npm run audit:deps && npm run validate:env",
    "security:validate-config": "grep -q 'usesCleartextTraffic=\"false\"' android/app/src/main/AndroidManifest.xml || (echo '❌ Android cleartext traffic not disabled in production' && exit 1)",
    "bundle:analyze": "npx react-native-bundle-visualizer",
    "bundle:analyze:android": "npx react-native-bundle-visualizer --platform android",
    "bundle:analyze:ios": "npx react-native-bundle-visualizer --platform ios",
    "clean": "rm -rf node_modules dist .expo",
    "prepare": "husky install",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^3.4.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-native-community/slider": "^5.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@sentry/react-native": "^8.11.0",
    "@sentry/tracing": "^7.120.4",
    "@shopify/flash-list": "^1.8.3",
    "@tanstack/react-query": "^5.90.7",
    "@testing-library/react": "^16.3.2",
    "@types/crypto-js": "^4.2.2",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "expo": "^54.0.23",
    "expo-blur": "^15.0.7",
    "expo-constants": "~18.0.9",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-linking": "~8.0.8",
    "expo-localization": "^55.0.13",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.8",
    "i18next": "^26.0.10",
    "immer": "^11.1.8",
    "react": "^19.0.0-rc.0",
    "react-dom": "^19.0.0-rc.0",
    "react-hook-form": "^7.51.0",
    "react-i18next": "^17.0.7",
    "react-native": "^0.82.0",
    "react-native-device-info": "^15.0.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-keychain": "^10.0.0",
    "react-native-logs": "^5.6.0",
    "react-native-mmkv": "^2.10.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-ssl-pinning": "^1.6.0",
    "react-native-svg": "^15.15.2",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@mswjs/data": "^0.16.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-inline-environment-variables": "^6.8.0",
    "esbuild": "^0.23.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-native": "^4.1.0",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "jest-expo": "^55.0.17",
    "lint-staged": "^15.2.0",
    "msw": "^2.14.5",
    "prettier": "^3.6.0",
    "react-native-bundle-visualizer": "^4.0.0",
    "react-native-testing-library": "^2.2.0",
    "react-test-renderer": "^19.2.4",
    "typescript": "^5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "private": true
}
