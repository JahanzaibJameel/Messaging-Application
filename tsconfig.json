{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "isolatedModules": true,
    "declaration": true,
    "sourceMap": true,
    "declarationMap": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "target": "ES2022",
    "module": "ESNext",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./client/src/*", "./client/*"],
      "@domain/*": ["./client/src/domain/*"],
      "@data/*": ["./client/src/data/*"],
      "@core/*": ["./client/src/core/*"],
      "@presentation/*": ["./client/src/presentation/*"],
      "@services/*": ["./client/src/services/*"],
      "@shared/*": ["./client/src/shared/*"],
      "@components/*": ["./client/components/*"],
      "@navigation/*": ["./client/navigation/*"],
      "@hooks/*": ["./client/hooks/*"],
      "@utils/*": ["./client/utils/*"],
      "@constants/*": ["./client/constants/*"],
      "@types/*": ["./client/types/*"],
      "@theme/*": ["./client/theme/*"],
      "@shared-root/*": ["./shared/*"]
    },
    "types": ["node", "react", "react-native", "jest"]
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
  "exclude": ["node_modules", "build", "dist", ".expo"]
}
